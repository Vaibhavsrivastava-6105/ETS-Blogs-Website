generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// User Model
model User {
  id           String    @id @default(uuid())
  clerkId      String    @unique // Synced from Clerk
  email        String    @unique
  firstName    String?
  lastName     String?
  profileImage String?
  bio          String?
  role         String    @default("USER") // USER, AUTHOR, ADMIN
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relationships
  articles     Article[]
  drafts       Draft[]
  comments     Comment[]
  bookmarks    Bookmark[]
}

// Category Model
model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())

  // Relationships
  articles    Article[]
}

// Tag Model
model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique

  // Relationships
  articles  Article[]
}

// Article Model
model Article {
  id              String    @id @default(uuid())
  title           String
  slug            String    @unique
  excerpt         String?
  content         String    // TipTap JSON or HTML
  coverImage      String?
  seoTitle        String?
  seoDescription  String?
  readingTime     Int       @default(0) // In minutes
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Foreign Keys
  authorId        String
  categoryId      String?

  // Relationships
  author          User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags            Tag[]
  comments        Comment[]
  bookmarks       Bookmark[]
}

// Draft Model (Auto-save feature)
model Draft {
  id          String    @id @default(uuid())
  title       String?
  content     String?
  lastSavedAt DateTime  @default(now())

  // Foreign Keys
  authorId    String

  // Relationships
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// Comment Model
model Comment {
  id        String    @id @default(uuid())
  content   String
  createdAt DateTime  @default(now())

  // Foreign Keys
  authorId  String
  articleId String

  // Relationships
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

// Bookmark Model (Saved Articles)
model Bookmark {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())

  // Foreign Keys
  userId    String
  articleId String

  // Relationships
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
}
